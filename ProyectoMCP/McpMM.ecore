<?xml version="1.0" encoding="UTF-8"?>
<ecore:EPackage xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:ecore="http://www.eclipse.org/emf/2002/Ecore" name="McpMM" nsURI="https://www.example.org/McpMM" nsPrefix="McpMM">
  <eAnnotations source="http://www.eclipse.org/emf/2002/GenModel">
    <details key="operationReflection" value="true"/>
    <details key="tableProviders" value="true"/>
    <details key="complianceLevel" value="8.0"/>
  </eAnnotations>
  <eAnnotations source="http://www.eclipse.org/OCL/Import">
    <details key="ecore" value="http://www.eclipse.org/emf/2002/Ecore"/>
  </eAnnotations>
  <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
    <details key="invocationDelegates" value="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"/>
    <details key="settingDelegates" value="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"/>
    <details key="validationDelegates" value="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"/>
  </eAnnotations>
  <eClassifiers xsi:type="ecore:EClass" name="VersionContexto">
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="valorAnterior" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="fechaModificacion" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="propiedadAsociada" eType="#//Propiedad"
        eOpposite="#//Propiedad/versiones"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ServiceMCP">
    <eAnnotations source="gmf.diagram"/>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Clase raíz que actúa como contenedor principal de todo el modelo de agentes y servicios."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreServicio" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="agentes" upperBound="-1"
        eType="#//Agente" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="servicios" upperBound="-1"
        eType="#//ServiceMCP" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="servidores" upperBound="-1"
        eType="#//ServerMCP" containment="true"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="workflows" upperBound="-1"
        eType="#//Workflow" containment="true"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="ServerMCP">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreServer"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="200,200,255"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Representa un servidor o infraestructura externa que expone operaciones MCP a las que los agentes pueden conectarse."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreServer" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="operaciones" upperBound="-1"
        eType="#//OperacionMCP" containment="true">
      <eAnnotations source="gmf.compartment">
        <details key="layout" value="list"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Agente">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R05_LimiteCargaTrabajo"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R05_LimiteCargaTrabajo" value="self.tareas->size() &lt;= 10"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombre"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,200,200"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombre" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="rol" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="tareas" upperBound="-1"
        eType="#//TareaEjecutable" eOpposite="#//TareaEjecutable/ejecutadaPor">
      <eAnnotations source="gmf.link">
        <details key="target.decoration" value="arrow"/>
        <details key="style" value="solid"/>
        <details key="color" value="0,0,0"/>
        <details key="label" value="ejecuta"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="contextos" upperBound="-1"
        eType="#//Contexto" containment="true">
      <eAnnotations source="gmf.compartment">
        <details key="layout" value="list"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Workflow">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R01_UnaTareaInicio R02_UnaTareaFin"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R01_UnaTareaInicio" value="self.tareas->select(t | t.oclIsTypeOf(Inicio))->size() = 1"/>
      <details key="R02_UnaTareaFin" value="self.tareas->select(t | t.oclIsTypeOf(Final))->size() = 1"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreWorkflow"/>
      <details key="figure" value="rounded"/>
      <details key="color" value="200,255,200"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Define el flujo de trabajo o comportamiento que sigue un agente mediante una secuencia de tareas."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreWorkflow" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="tareas" lowerBound="1"
        upperBound="-1" eType="#//Tarea" containment="true">
      <eAnnotations source="gmf.compartment">
        <details key="layout" value="free"/>
      </eAnnotations>
    </eStructuralFeatures>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Contexto">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreContexto"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,255,200"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Representa el estado o conjunto de datos compartidos durante la ejecución del workflow de un agente."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreContexto" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="propiedades" upperBound="-1"
        eType="#//Propiedad" containment="true">
      <eAnnotations source="gmf.compartment">
        <details key="layout" value="list"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="esApuntadoPor" upperBound="-1"
        eType="#//Accion" eOpposite="#//Accion/apunta"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Propiedad">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombrePropiedad"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombrePropiedad" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="tipoPropiedad" eType="#//TipoContexto"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="extensionPermitida" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="pesoMaxMB" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="esUsada" upperBound="-1"
        eType="#//Accion" eOpposite="#//Accion/usa"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="versiones" upperBound="-1"
        eType="#//VersionContexto" containment="true" eOpposite="#//VersionContexto/propiedadAsociada"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Tarea" abstract="true">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R10_NoBuclePropio"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R10_NoBuclePropio" value="self.sigue &lt;> self"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Clase base abstracta para todos los pasos ejecutables y puntos de control dentro de un workflow."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreTarea" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="taskId" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EInt"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="taskDesc" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="accion" upperBound="-1"
        eType="#//Accion" containment="true">
      <eAnnotations source="gmf.compartment">
        <details key="layout" value="list"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="precede" upperBound="-1"
        eType="#//Tarea" eOpposite="#//Tarea/sigue"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sigue" eType="#//Tarea"
        eOpposite="#//Tarea/precede">
      <eAnnotations source="gmf.link">
        <details key="target.decoration" value="arrow"/>
        <details key="color" value="0,0,0"/>
        <details key="label" value="sigue"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EReference" name="precedeElse" upperBound="-1"
        eType="#//TareaAnalisis" eOpposite="#//TareaAnalisis/sigueElse"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaEjecutable" abstract="true" eSuperTypes="#//Tarea">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R09_EntradaYSalida R08_ConexionesMismoAgente"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R09_EntradaYSalida" value="(self.precede->notEmpty() or self.precedeElse->notEmpty()) and not self.sigue.oclIsUndefined()"/>
      <details key="R08_ConexionesMismoAgente" value="self.sigue.oclIsKindOf(McpMM::TareaEjecutable) implies ( (self.oclIsTypeOf(McpMM::TareaEnvioContexto) and self.sigue.oclIsTypeOf(McpMM::TareaRecepcionContexto)) or (self.ejecutadaPor = self.sigue.oclAsType(McpMM::TareaEjecutable).ejecutadaPor) )"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ejecutadaPor" lowerBound="1"
        eType="#//Agente" eOpposite="#//Agente/tareas"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Inicio" eSuperTypes="#//Tarea">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R03_InicioSinEntradas"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R03_InicioSinEntradas" value="self.precede->isEmpty() and self.precedeElse->isEmpty()"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="ellipse"/>
      <details key="color" value="0,255,0"/>
      <details key="size" value="30,30"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Final" eSuperTypes="#//Tarea">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R04_FinSinSalidas"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R04_FinSinSalidas" value="self.sigue.oclIsUndefined()"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="ellipse"/>
      <details key="color" value="255,0,0"/>
      <details key="size" value="30,30"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Nodo final que indica la terminación lógica de un workflow."/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Accion" abstract="true">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R12_CoherenciaContexto"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R12_CoherenciaContexto" value="self.usa->forAll(p | self.apunta.propiedades->includes(p))"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Clase abstracta que modela las interacciones (lectura/escritura) que una tarea realiza sobre un contexto de datos."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreAccion" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="apunta" lowerBound="1"
        eType="#//Contexto" eOpposite="#//Contexto/esApuntadoPor"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="usa" upperBound="-1" eType="#//Propiedad"
        eOpposite="#//Propiedad/esUsada"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Escritura" eSuperTypes="#//Accion">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreAccion"/>
      <details key="figure" value="rectangle"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Acción que modifica, actualiza o inserta nuevos datos en un contexto."/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="Lectura" eSuperTypes="#//Accion">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreAccion"/>
      <details key="figure" value="rectangle"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Acción que obtiene o consume datos de un contexto para su procesamiento."/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EEnum" name="TipoContexto">
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Enumeración de los tipos de datos básicos y complejos permitidos en las propiedades de un contexto."/>
    </eAnnotations>
    <eLiterals name="ENTERO"/>
    <eLiterals name="CADENA" value="1"/>
    <eLiterals name="REAL" value="2"/>
    <eLiterals name="BOOLEANO" value="3"/>
    <eLiterals name="TEXTO_EXTENSO" value="4"/>
    <eLiterals name="ARCHIVO" value="5"/>
    <eLiterals name="COLECCION_ARCHIVOS" value="6"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="OperacionMCP">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreOperacion"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Define una operación específica disponible en un ServerMCP que puede ser invocada de manera remota."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="nombreOperacion" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="descOperacion" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
    <eStructuralFeatures xsi:type="ecore:EReference" name="esEjecutadaOperacion" eType="#//TareaServerMCP"
        eOpposite="#//TareaServerMCP/ejecutaOperacion"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaTransformacionDatos" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="200,255,255"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Tarea encargada de transformar o reformatear un conjunto de datos en base a una regla o prompt."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prompt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaLLM" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,200,255"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Tarea que invoca a un Modelo de Lenguaje Grande (LLM) utilizando un prompt específico para razonamiento o generación de texto."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prompt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaUsuario" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,255,255"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Tarea interactiva que detiene el flujo para requerir intervención o entrada de datos manual por parte de un usuario humano."/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaAnalisis" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,255,150"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Tarea de bifurcación condicional que evalúa un estado para decidir continuar por el flujo principal o por un flujo alternativo (Else)."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sigueElse" lowerBound="1"
        eType="#//Tarea" eOpposite="#//Tarea/precedeElse">
      <eAnnotations source="gmf.link">
        <details key="target.decoration" value="arrow"/>
        <details key="label" value="sigue Else"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prompt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaEnvioContexto" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="150,255,150"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Subclase de TareaEjecutable que permite exportar el contexto actual de un flujo para que sea procesado por otro agente."/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaRecepcionContexto" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R07_RecepcionPrecedidaEnvio R11_MismasPropiedadesEnvioRecepcion R08_DistintosAgentes"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R07_RecepcionPrecedidaEnvio" value="self.precede->exists(t | t.oclIsTypeOf(TareaEnvioContexto))"/>
      <details key="R11_MismasPropiedadesEnvioRecepcion" value="self.precede->select(t | t.oclIsTypeOf(TareaEnvioContexto))->forAll(e | self.accion->collect(usa)->asSet() = e.accion->collect(usa)->asSet())"/>
      <details key="R08_DistintosAgentes" value="self.precede->select(t | t.oclIsTypeOf(TareaEnvioContexto))->forAll(e | self.ejecutadaPor &lt;> e.oclAsType(TareaEjecutable).ejecutadaPor)"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="150,150,255"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaServerMCP" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="200,200,200"/>
    </eAnnotations>
    <eAnnotations source="DSLDoc">
      <details key="descripcion" value="Tarea automatizada que se conecta a un ServerMCP para invocar remotamente una OperacionMCP específica."/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="ejecutaOperacion" lowerBound="1"
        eType="#//OperacionMCP" eOpposite="#//OperacionMCP/esEjecutadaOperacion">
      <eAnnotations source="gmf.link">
        <details key="target.decoration" value="arrow"/>
        <details key="style" value="dash"/>
        <details key="label" value="ejecuta oper."/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prompt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
</ecore:EPackage>
