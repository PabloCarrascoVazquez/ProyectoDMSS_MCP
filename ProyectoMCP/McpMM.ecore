      <details key="figure" value="rectangle"/>
      <details key="color" value="255,255,255"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaAnalisis" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="255,255,150"/>
    </eAnnotations>
    <eStructuralFeatures xsi:type="ecore:EReference" name="sigueElse" lowerBound="1"
        eType="#//Tarea" eOpposite="#//Tarea/precedeElse">
      <eAnnotations source="gmf.link">
        <details key="target.decoration" value="arrow"/>
        <details key="label" value="sigue Else"/>
      </eAnnotations>
    </eStructuralFeatures>
    <eStructuralFeatures xsi:type="ecore:EAttribute" name="prompt" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaEnvioContexto" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="150,255,150"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaRecepcionContexto" eSuperTypes="#//TareaEjecutable">
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore">
      <details key="constraints" value="R07_RecepcionPrecedidaEnvio R11_MismasPropiedadesEnvioRecepcion"/>
    </eAnnotations>
    <eAnnotations source="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot">
      <details key="R07_RecepcionPrecedidaEnvio" value="not self.precede.oclIsUndefined() and self.precede.oclIsTypeOf(TareaEnvioContexto)"/>
      <details key="R11_MismasPropiedadesEnvioRecepcion" value="if not self.precede.oclIsUndefined() and self.precede.oclIsTypeOf(TareaEnvioContexto) then self.accion->collect(usa)->asSet() = self.precede.accion->collect(usa)->asSet() else true endif"/>
    </eAnnotations>
    <eAnnotations source="gmf.node">
      <details key="label" value="nombreTarea"/>
      <details key="figure" value="rectangle"/>
      <details key="color" value="150,150,255"/>
    </eAnnotations>
  </eClassifiers>
  <eClassifiers xsi:type="ecore:EClass" name="TareaServerMCP" eSuperTypes="#//TareaEjecutable">
