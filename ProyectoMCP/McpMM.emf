@GenModel(operationReflection="true", tableProviders="true", complianceLevel="8.0")
@"http://www.eclipse.org/OCL/Import"(ecore="http://www.eclipse.org/emf/2002/Ecore")
@Ecore(invocationDelegates="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot", settingDelegates="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot", validationDelegates="http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot")
@namespace(uri="https://www.example.org/McpMM", prefix="McpMM")
package McpMM;

// EXTENSIÓN 1: Historial de contexto
class VersionContexto {
    attr String valorAnterior;
    attr String fechaModificacion;
    ref Propiedad#versiones propiedadAsociada;
}

@gmf.diagram
@"DSLDoc"(descripcion="Clase raíz que actúa como contenedor principal de todo el modelo de agentes y servicios.")
class ServiceMCP {
	attr String nombreServicio;
	
	val Agente[*] agentes;
	val ServiceMCP[*] servicios;
	val ServerMCP[*] servidores;
	val Workflow[*] workflows;
}

@gmf.node(label="nombreServer", figure="rectangle", color="200,200,255")
@"DSLDoc"(descripcion="Representa un servidor o infraestructura externa que expone operaciones MCP a las que los agentes pueden conectarse.")
class ServerMCP {
	attr String nombreServer;
	
	@gmf.compartment(layout="list")
	val OperacionMCP[*] operaciones;
}

@Ecore(constraints="R05_LimiteCargaTrabajo")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
    R05_LimiteCargaTrabajo="self.tareas->size() <= 10"
)
@gmf.node(label="nombre", figure="rectangle", color="255,200,200")
class Agente {
    attr String nombre;
    attr String rol;

    @gmf.link(target.decoration="arrow", style="solid", color="0,0,0", label="ejecuta")
    ref TareaEjecutable[*]#ejecutadaPor tareas; 
    
    @gmf.compartment(layout="list")
    val Contexto[*] contextos;
}

@Ecore(constraints="R01_UnaTareaInicio R02_UnaTareaFin")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
	R01_UnaTareaInicio="self.tareas->select(t | t.oclIsTypeOf(Inicio))->size() = 1", 
	R02_UnaTareaFin="self.tareas->select(t | t.oclIsTypeOf(Final))->size() = 1"
)
@gmf.node(label="nombreWorkflow", figure="rounded", color="200,255,200")
@"DSLDoc"(descripcion="Define el flujo de trabajo o comportamiento que sigue un agente mediante una secuencia de tareas.")
class Workflow {
	attr String nombreWorkflow;
	
	@gmf.compartment(layout="free")
	val Tarea[+] tareas;
}

@gmf.node(label="nombreContexto", figure="rectangle", color="255,255,200")
@"DSLDoc"(descripcion="Representa el estado o conjunto de datos compartidos durante la ejecución del workflow de un agente.")
class Contexto {
	attr String nombreContexto;
	
	@gmf.compartment(layout="list")
	val Propiedad[*] propiedades;
	
	ref Accion[*]#apunta esApuntadoPor;
}

@gmf.node(label="nombrePropiedad")
class Propiedad {
    attr String nombrePropiedad;
    attr TipoContexto tipoPropiedad;
    
    attr String extensionPermitida; 
    attr int pesoMaxMB;            
    
    ref Accion[*]#usa esUsada;
    
    val VersionContexto[*]#propiedadAsociada versiones; 
}

@Ecore(constraints="R10_NoBuclePropio")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
	R10_NoBuclePropio="self.sigue <> self"
)
@"DSLDoc"(descripcion="Clase base abstracta para todos los pasos ejecutables y puntos de control dentro de un workflow.")
abstract class Tarea {
	attr String nombreTarea;
	attr int taskId;
	attr String taskDesc;
	
	@gmf.compartment(layout="list")
	val Accion[*] accion;
	
	ref Tarea[*]#sigue precede;
	
	@gmf.link(target.decoration="arrow", color="0,0,0", label="sigue")
	ref Tarea#precede sigue;
	
	ref TareaAnalisis[*]#sigueElse precedeElse;
}

@Ecore(constraints="R09_EntradaYSalida")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
	R09_EntradaYSalida="(self.precede->notEmpty() or self.precedeElse->notEmpty()) and not self.sigue.oclIsUndefined()"
)
@"DSLDoc"(descripcion="Clase base para aquellas tareas.")
abstract class TareaEjecutable extends Tarea {
    ref Agente[1]#tareas ejecutadaPor;
}

@Ecore(constraints="R03_InicioSinEntradas")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
    R03_InicioSinEntradas="self.precede->isEmpty() and self.precedeElse->isEmpty()"
)
@gmf.node(label="nombreTarea", figure="ellipse", color="0,255,0", size="30,30")
class Inicio extends Tarea {
}

@Ecore(constraints="R04_FinSinSalidas")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
    R04_FinSinSalidas="self.sigue.oclIsUndefined()"
)
@gmf.node(label="nombreTarea", figure="ellipse", color="255,0,0", size="30,30")
@"DSLDoc"(descripcion="Nodo final que indica la terminación lógica de un workflow.")
class Final extends Tarea {
}

@Ecore(constraints="R12_CoherenciaContexto")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
    R12_CoherenciaContexto="self.usa->forAll(p | self.apunta.propiedades->includes(p))"
)
@"DSLDoc"(descripcion="Clase abstracta que modela las interacciones (lectura/escritura) que una tarea realiza sobre un contexto de datos.")
abstract class Accion {
	attr String nombreAccion;
	
	ref Contexto[1]#esApuntadoPor apunta;
	ref Propiedad[*]#esUsada usa;
}

@gmf.node(label="nombreAccion", figure="rectangle")
@"DSLDoc"(descripcion="Acción que modifica, actualiza o inserta nuevos datos en un contexto.")
class Escritura extends Accion {
}

@gmf.node(label="nombreAccion", figure="rectangle")
@"DSLDoc"(descripcion="Acción que obtiene o consume datos de un contexto para su procesamiento.")
class Lectura extends Accion {
}

@"DSLDoc"(descripcion="Enumeración de los tipos de datos básicos y complejos permitidos en las propiedades de un contexto.")
enum TipoContexto {
	ENTERO = 0;
	CADENA = 1;
	REAL = 2;
	BOOLEANO = 3;
	TEXTO_EXTENSO = 4;
	ARCHIVO = 5;
	COLECCION_ARCHIVOS = 6;
}

@gmf.node(label="nombreOperacion")
@"DSLDoc"(descripcion="Define una operación específica disponible en un ServerMCP que puede ser invocada de manera remota.")
class OperacionMCP {
	attr String nombreOperacion;
	attr String descOperacion;
	ref TareaServerMCP#ejecutaOperacion esEjecutadaOperacion;
}

@gmf.node(label="nombreTarea", figure="rectangle", color="200,255,255")
@"DSLDoc"(descripcion="Tarea encargada de transformar o reformatear un conjunto de datos en base a una regla o prompt.")
class TareaTransformacionDatos extends TareaEjecutable {
	attr String prompt;
}

@gmf.node(label="nombreTarea", figure="rectangle", color="255,200,255")
@"DSLDoc"(descripcion="Tarea que invoca a un Modelo de Lenguaje Grande (LLM) utilizando un prompt específico para razonamiento o generación de texto.")
class TareaLLM extends TareaEjecutable {
	attr String prompt;
}

@gmf.node(label="nombreTarea", figure="rectangle", color="255,255,255")
@"DSLDoc"(descripcion="Tarea interactiva que detiene el flujo para requerir intervención o entrada de datos manual por parte de un usuario humano.")
class TareaUsuario extends TareaEjecutable {
}

@gmf.node(label="nombreTarea", figure="rectangle", color="255,255,150")
@"DSLDoc"(descripcion="Tarea de bifurcación condicional que evalúa un estado para decidir continuar por el flujo principal o por un flujo alternativo (Else).")
class TareaAnalisis extends TareaEjecutable {
	@gmf.link(target.decoration="arrow", label="sigue Else")
	ref Tarea[1]#precedeElse sigueElse;
	attr String prompt;
}

@gmf.node(label="nombreTarea", figure="rectangle", color="150,255,150")
@"DSLDoc"(descripcion="Subclase de TareaEjecutable que permite exportar el contexto actual de un flujo para que sea procesado por otro agente.")
class TareaEnvioContexto extends TareaEjecutable {
}

@Ecore(constraints="R07_RecepcionPrecedidaEnvio R11_MismasPropiedadesEnvioRecepcion R08_DistintosAgentes")
@"http://www.eclipse.org/emf/2002/Ecore/OCL/Pivot"(
	R07_RecepcionPrecedidaEnvio="self.precede->exists(t | t.oclIsTypeOf(TareaEnvioContexto))", 
	R11_MismasPropiedadesEnvioRecepcion="self.precede->select(t | t.oclIsTypeOf(TareaEnvioContexto))->forAll(e | self.accion->collect(usa)->asSet() = e.accion->collect(usa)->asSet())",
	R08_DistintosAgentes="self.precede->select(t | t.oclIsTypeOf(TareaEnvioContexto))->forAll(e | self.ejecutadaPor <> e.oclAsType(TareaEjecutable).ejecutadaPor)"
)
@gmf.node(label="nombreTarea", figure="rectangle", color="150,150,255")
class TareaRecepcionContexto extends TareaEjecutable {
}

@gmf.node(label="nombreTarea", figure="rectangle", color="200,200,200")
@"DSLDoc"(descripcion="Tarea automatizada que se conecta a un ServerMCP para invocar remotamente una OperacionMCP específica.")
class TareaServerMCP extends TareaEjecutable {
	@gmf.link(target.decoration="arrow", style="dash", label="ejecuta oper.")
	ref OperacionMCP[1]#esEjecutadaOperacion ejecutaOperacion;
	attr String prompt;
}