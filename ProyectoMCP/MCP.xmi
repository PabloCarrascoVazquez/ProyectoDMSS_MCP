<?xml version="1.0" encoding="UTF-8"?>
<McpMM:ServiceMCP
    xmi:version="2.0"
    xmlns:xmi="http://www.omg.org/XMI"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:McpMM="https://www.example.org/McpMM"
    nombreServicio="Sistema_Facturacion_IA">
  
  <agente nombreAgente="Agente_Facturacion" realiza="//@workflow.0/@tarea.1 //@workflow.0/@tarea.2"/>
  
  <workflow
      nombreWorkflow="Flujo_Consultar_Factura"
      finalizaCon="//@workflow.0/@tarea.3"
      empiezaCon="//@workflow.0/@tarea.0">
      
    <tarea xsi:type="McpMM:TareaInicial"
        nombreTarea="Inicio_Consulta"
        sigue="//@workflow.0/@tarea.1"
        empieza="//@workflow.0"/>
        
    <tarea xsi:type="McpMM:TareaUsuario"
        nombreTarea="Ingresar_ID_Factura"
        agenteAsignado="//@agente.0"
        sigue="//@workflow.0/@tarea.2"
        precede="//@workflow.0/@tarea.0"
        idTarea="1"
        descTarea="El usuario teclea el ID"/>
        
    <tarea xsi:type="McpMM:TareaServerMCP"
        nombreTarea="Ejecutar_Busqueda"
        agenteAsignado="//@agente.0"
        sigue="//@workflow.0/@tarea.3"
        precede="//@workflow.0/@tarea.1"
        idTarea="2"
        descTarea="Llama a la BD usando el MCP"
        ejecutaOperacion="//@servermcp.0/@operacionmcp.0"
        prompt="Trae los datos de esta factura"/>
        
    <tarea xsi:type="McpMM:TareaFinal"
        nombreTarea="Fin_Consulta"
        precede="//@workflow.0/@tarea.2"
        finaliza="//@workflow.0"/>
        
    <contexto
        nombreContexto="Contexto_Datos_Factura">
      <propiedad
          nombrePropiedad="id_factura"
          tipoPropiedad="ENTERO"/>
      <propiedad
          nombrePropiedad="resultado_json"
          tipoPropiedad="CADENA"/>
    </contexto>
  </workflow>
  
  <servermcp
      nombreServer="Servidor_BBDD_Local">
    <operacionmcp
        nombreOperacion="Buscar_Factura"
        descOperacion="Busca una factura por ID en la base de datos"
        esEjecutadaOperacion="//@workflow.0/@tarea.2"/>
  </servermcp>
  
</McpMM:ServiceMCP>