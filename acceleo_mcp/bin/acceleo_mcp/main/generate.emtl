            <body xsi:type="ocl.ecore:StringLiteralExp" stringSymbol="            &lt;div class=&quot;box&quot; style=&quot;border-left: 4px solid #34495e;&quot;>&#xD;&#xA;                &lt;h3>Ejecución en Servidor Remoto (MCP)&lt;/h3>&#xD;&#xA;                &lt;p>&lt;strong>Operación a ejecutar:&lt;/strong>&lt;/p>&#xD;&#xA;                &lt;pre style=&quot;background:#2c3e50; color:#ecf0f1; padding:15px; border-radius:4px;&quot;>"/>
